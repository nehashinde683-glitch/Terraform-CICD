pipeline {
    agent any
 
    stages {
 
        stage('Checkout') {
            steps {
            git branch: 'main', url: 'https://github.com/nehashinde683-glitch/Terraform-Practice.git'
            }
        }
 
        stage('Terraform Init') {
            steps {
                dir('Day2-sample-base-code') {
                    sh 'terraform init'
                }
            }
        }
 
        stage('Terraform Plan') {
            steps {
                dir('Day2-sample-base-code') {
                    sh 'terraform plan -out=tfplan'
                }
            }
        }
 
        stage('Terraform Apply') {
            steps {
                dir('Day2-sample-base-code') {
                    sh 'terraform apply -auto-approve tfplan'
                }
            }
        }
    }
}
